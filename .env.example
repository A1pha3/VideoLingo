# VideoLingo Environment Variables Configuration
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# ======================== Basic API Settings ========================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_LLM_SUPPORT_JSON=true

# ======================== Whisper / ASR Settings ========================
# 302.ai API key (for cloud whisper)
WHISPER_302_API_KEY=your_302_api_key_here
# ElevenLabs API key (experimental)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Runtime: local, cloud, or elevenlabs
WHISPER_RUNTIME=local

# ======================== TTS Settings ========================
# TTS method: sf_fish_tts, openai_tts, gpt_sovits, azure_tts, fish_tts, edge_tts, custom_tts
TTS_METHOD=azure_tts

# SiliconFlow FishTTS
SF_FISH_API_KEY=your_siliconflow_api_key_here
SF_FISH_MODE=preset

# OpenAI TTS (302.ai)
OPENAI_TTS_API_KEY=your_302_api_key_here
OPENAI_TTS_VOICE=alloy

# Azure TTS (302.ai)
AZURE_TTS_API_KEY=your_302_api_key_here
AZURE_TTS_VOICE=zh-CN-YunfengNeural

# FishTTS (302.ai)
FISH_TTS_API_KEY=your_302_api_key_here
FISH_TTS_CHARACTER=AD学姐

# SiliconFlow CosyVoice2
SF_COSYVOICE2_API_KEY=your_siliconflow_api_key_here

# F5-TTS (302.ai)
F5TTS_302_API_KEY=your_302_api_key_here

# ======================== Advanced Settings ========================
# YouTube cookies file path (for downloading restricted videos)
YOUTUBE_COOKIES_PATH=

# Threading
MAX_WORKERS=4

# Feature toggles
DEMUCS_ENABLED=true
BURN_SUBTITLES=true
FFMPEG_GPU=false
REFLECT_TRANSLATE=true
PAUSE_BEFORE_TRANSLATE=false

# Language
TARGET_LANGUAGE=简体中文

# Summary length
SUMMARY_LENGTH=8000
MAX_SPLIT_LENGTH=20

# Subtitle settings
SUBTITLE_MAX_LENGTH=75
SUBTITLE_TARGET_MULTIPLIER=1.2

# Model cache directory
MODEL_DIR=./_model_cache

# YouTube download resolution
YTB_RESOLUTION=1080
