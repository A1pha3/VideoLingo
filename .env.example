# VideoLingo Environment Variables Configuration
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# Only sensitive API keys belong here.
# All non-sensitive runtime settings should be edited in config.yaml or via the Streamlit page.

# ======================== LLM ========================
MINIMAX_API_KEY=your_minimax_api_key_here

# ======================== Whisper / ASR ========================
WHISPER_302_API_KEY=your_302_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ======================== TTS Settings ========================
SF_FISH_API_KEY=your_siliconflow_api_key_here
OPENAI_TTS_API_KEY=your_302_api_key_here
AZURE_TTS_API_KEY=your_302_api_key_here
FISH_TTS_API_KEY=your_302_api_key_here
SF_COSYVOICE2_API_KEY=your_siliconflow_api_key_here
F5TTS_302_API_KEY=your_302_api_key_here
